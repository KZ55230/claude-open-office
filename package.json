{
  "name": "claude-open-office",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p server/tsconfig.json --noEmit",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "test:layout": "node --experimental-strip-types client/src/layout.test.ts",
    "start": "cross-env NODE_ENV=production tsx server/src/index.ts"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.1.0",
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "pixi.js": "^8.6.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
